@Article{CampbellShiller88,
  author    = {John Y. Campbell and Robert J. Shiller},
  journal   = {The Review of Financial Studies},
  title     = {The Dividend-Price Ratio and Expectations of Future Dividends and Discount Factors},
  year      = {1988},
  issn      = {08939454, 14657368},
  number    = {3},
  pages     = {195--228},
  volume    = {1},
  abstract  = {A dividend-ratio model is introduced here that makes the log of the dividend-price ratio on a stock linear in optimally forecast future one-period real discount rates and future one-period growth rates of real dividends. If ex post discount rates are observable, this model can be tested by using vector autoregressive methods. Four versions of the linearized model, differing in the measure of discount rates, are tested for U.S. time series 1871-1986 and 1926-1986: a version that imposes constant real discount rates, and versions that measure discount rates from real interest rate data, aggregate real consumption data, and return variance data. The results yield a metric to judge the relative importance of real dividend growth, measured real discount rates, and unexplained factors in determining the dividend-price ratio.},
  publisher = {[Oxford University Press, Society for Financial Studies]},
  url       = {http://www.jstor.org/stable/2961997},
  urldate   = {2022-11-18},
}



@Article{CochraneDog,
  author    = {John H. Cochrane},
  journal   = {The Review of Financial Studies},
  title     = {The Dog That Did Not Bark: A Defense of Return Predictability},
  year      = {2008},
  issn      = {08939454, 14657368},
  number    = {4},
  pages     = {1533--1575},
  volume    = {21},
  abstract  = {If returns are not predictable, dividend growth must be predictable, to generate the observed variation in divided yields. I find that the absence of dividend growth predictability gives stronger evidence than does the presence of return predictability. Long-horizon return forecasts give the same strong evidence. These tests exploit the negative correlation of return forecasts with dividend-yield autocorrelation across samples, together with sensible upper bounds on dividend-yield autocorrelation, to deliver more powerful statistics. I reconcile my findings with the literature that finds poor power in long-horizon return forecasts, and with the literature that notes the poor out-of-sample R² of return-forecasting regressions.},
  publisher = {[Oxford University Press, Society for Financial Studies]},
  url       = {http://www.jstor.org/stable/40056861},
  urldate   = {2022-11-18},
}

