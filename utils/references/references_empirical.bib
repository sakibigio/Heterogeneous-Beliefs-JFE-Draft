@article{greenwood_bubbles_2019,
	title = {Bubbles for {Fama}},
	volume = {131},
	issn = {0304-405X},
	url = {https://www.sciencedirect.com/science/article/pii/S0304405X1830254X},
	doi = {10.1016/j.jfineco.2018.09.002},
	abstract = {We evaluate Eugene F. Fama's claim that stock prices do not exhibit price bubbles. Based on US industry returns (1926‒2014) and international sector returns (1985‒2014), we present four findings (1) Fama is correct in that a sharp price increase of an industry portfolio does not, on average, predict unusually low returns going forward; (2) such sharp price increases predict a substantially heightened probability of a crash but not of a further price boom; (3) attributes of the price run-up, including volatility, turnover, issuance, and the price path of the run-up, help forecast an eventual crash; and (4) these attributes also help forecast future returns. Results hold similarly in US and international samples.},
	language = {en},
	number = {1},
	urldate = {2021-11-19},
	journal = {Journal of Financial Economics},
	author = {Greenwood, Robin and Shleifer, Andrei and You, Yang},
	month = jan,
	year = {2019},
	keywords = {Bubble, Market efficiency, Predictability},
	pages = {20--43},
	file = {ScienceDirect Snapshot:C\:\\Users\\sakib\\Zotero\\storage\\2FTDP6PB\\S0304405X1830254X.html:text/html},
}

@article{barberis_extrapolation_2018,
	title = {Extrapolation and bubbles},
	volume = {129},
	issn = {0304-405X},
	url = {https://www.sciencedirect.com/science/article/pii/S0304405X18301016},
	doi = {10.1016/j.jfineco.2018.04.007},
	abstract = {We present an extrapolative model of bubbles. In the model, many investors form their demand for a risky asset by weighing two signals—an average of the asset’s past price changes and the asset’s degree of overvaluation—and “waver” over time in the relative weight they put on them. The model predicts that good news about fundamentals can trigger large price bubbles, that bubbles will be accompanied by high trading volume, and that volume increases with past asset returns. We present empirical evidence that bears on some of the model’s distinctive predictions.},
	language = {en},
	number = {2},
	urldate = {2021-11-19},
	journal = {Journal of Financial Economics},
	author = {Barberis, Nicholas and Greenwood, Robin and Jin, Lawrence and Shleifer, Andrei},
	month = aug,
	year = {2018},
	keywords = {Bubble, Extrapolation, Volume},
	pages = {203--227},
	file = {ScienceDirect Snapshot:C\:\\Users\\sakib\\Zotero\\storage\\75ZYCYGA\\S0304405X18301016.html:text/html;Full Text:C\:\\Users\\sakib\\Zotero\\storage\\37R2T977\\Barberis et al. - 2018 - Extrapolation and bubbles.pdf:application/pdf},
}

@article{barberis_x-capm_2015,
	title = {X-{CAPM}: {An} extrapolative capital asset pricing model},
	volume = {115},
	issn = {0304-405X},
	shorttitle = {X-{CAPM}},
	url = {https://www.sciencedirect.com/science/article/pii/S0304405X14001822},
	doi = {10.1016/j.jfineco.2014.08.007},
	abstract = {Survey evidence suggests that many investors form beliefs about future stock market returns by extrapolating past returns. Such beliefs are hard to reconcile with existing models of the aggregate stock market. We study a consumption-based asset pricing model in which some investors form beliefs about future price changes in the stock market by extrapolating past price changes, while other investors hold fully rational beliefs. We find that the model captures many features of actual prices and returns; importantly, however, it is also consistent with the survey evidence on investor expectations.},
	language = {en},
	number = {1},
	urldate = {2021-11-19},
	journal = {Journal of Financial Economics},
	author = {Barberis, Nicholas and Greenwood, Robin and Jin, Lawrence and Shleifer, Andrei},
	month = jan,
	year = {2015},
	keywords = {Expectations, Extrapolation, Predictability, Volatility},
	pages = {1--24},
	file = {ScienceDirect Snapshot:C\:\\Users\\sakib\\Zotero\\storage\\AFKVSQWT\\S0304405X14001822.html:text/html;Full Text:C\:\\Users\\sakib\\Zotero\\storage\\IF3C7AXV\\Barberis et al. - 2015 - X-CAPM An extrapolative capital asset pricing mod.pdf:application/pdf},
}

@article{greenwood_stock_2011,
	title = {Stock price fragility},
	volume = {102},
	issn = {0304-405X},
	url = {https://www.sciencedirect.com/science/article/pii/S0304405X11001474},
	doi = {10.1016/j.jfineco.2011.06.003},
	abstract = {We study the relation between the ownership structure of financial assets and non-fundamental risk. We define an asset to be fragile if it is susceptible to non-fundamental shifts in demand. An asset can be fragile because of concentrated ownership, or because its owners face correlated or volatile liquidity shocks, i.e., they must buy or sell at the same time. We formalize this idea and apply it to mutual fund ownership of US stocks. Consistent with our predictions, fragility strongly predicts price volatility. We then extend the logic of fragility to investigate two natural extensions: (1) the forecast of stock return comovement and (2) the potentially destabilizing impact of arbitrageurs on stock prices.},
	language = {en},
	number = {3},
	urldate = {2021-11-19},
	journal = {Journal of Financial Economics},
	author = {Greenwood, Robin and Thesmar, David},
	month = dec,
	year = {2011},
	keywords = {Flow-driven trading, Mutual funds, Non-fundamental risk},
	pages = {471--490},
	file = {ScienceDirect Snapshot:C\:\\Users\\sakib\\Zotero\\storage\\EEMYCFKS\\S0304405X11001474.html:text/html},
}

@article{greenwood_investor_2009,
	title = {Investor activism and takeovers},
	volume = {92},
	issn = {0304-405X},
	url = {https://www.sciencedirect.com/science/article/pii/S0304405X09000397},
	doi = {10.1016/j.jfineco.2008.05.005},
	abstract = {Recent work documents large positive abnormal returns when a hedge fund announces activist intentions regarding a publicly listed firm. We show that these returns are largely explained by the ability of activists to force target firms into a takeover. For a comprehensive sample of 13D filings by portfolio investors between 1993 and 2006, announcement returns and long-term abnormal returns are high for targets that are ultimately acquired, but not detectably different from zero for firms that remain independent. Firms targeted by activists are more likely than control firms to get acquired. Finally, activist investors’ portfolios perform poorly during a period in which market wide takeover interest declined.},
	language = {en},
	number = {3},
	urldate = {2021-11-19},
	journal = {Journal of Financial Economics},
	author = {Greenwood, Robin and Schor, Michael},
	month = jun,
	year = {2009},
	keywords = {Corporate control, Event studies, Hedge funds, Investor activism},
	pages = {362--375},
	file = {ScienceDirect Snapshot:C\:\\Users\\sakib\\Zotero\\storage\\2A5U4JP8\\S0304405X09000397.html:text/html},
}

@article{greenwood_inexperienced_2009,
	title = {Inexperienced investors and bubbles},
	volume = {93},
	issn = {0304-405X},
	url = {https://www.sciencedirect.com/science/article/pii/S0304405X09000646},
	doi = {10.1016/j.jfineco.2008.08.004},
	abstract = {We use mutual fund manager data from the technology bubble to examine the hypothesis that inexperienced investors play a role in the formation of asset price bubbles. Using age as a proxy for managers’ investment experience, we find that around the peak of the technology bubble, mutual funds run by younger managers are more heavily invested in technology stocks, relative to their style benchmarks, than their older colleagues. Furthermore, young managers, but not old managers, exhibit trend-chasing behavior in their technology stock investments. As a result, young managers increase their technology holdings during the run-up, and decrease them during the downturn. Both results are in line with the behavior of inexperienced investors in experimental asset markets. The economic significance of young managers’ actions is amplified by large inflows into their funds prior to the peak in technology stock prices.},
	language = {en},
	number = {2},
	urldate = {2021-11-19},
	journal = {Journal of Financial Economics},
	author = {Greenwood, Robin and Nagel, Stefan},
	month = aug,
	year = {2009},
	keywords = {Asset price bubbles, Investment experience, Investor age, Trend chasing},
	pages = {239--258},
	file = {ScienceDirect Snapshot:C\:\\Users\\sakib\\Zotero\\storage\\29M286NT\\S0304405X09000646.html:text/html;Full Text:C\:\\Users\\sakib\\Zotero\\storage\\R6HDZPWL\\Greenwood and Nagel - 2009 - Inexperienced investors and bubbles.pdf:application/pdf},
}

@article{greenwood_short-_2005,
	title = {Short- and long-term demand curves for stocks: theory and evidence on the dynamics of arbitrage},
